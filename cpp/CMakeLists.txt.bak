cmake_minimum_required(VERSION 3.10)
project(Adhan)

add_library(
    Adhan
    STATIC
    NativeAdhan.cpp
    PrayerTimes.cpp
    AdhanCalculations.cpp
    third_party/adhan-cpp/src/Astronomical.cpp
    third_party/adhan-cpp/src/PrayerTimes.cpp
    third_party/adhan-cpp/src/SolarTime.cpp
)

target_include_directories(
    Adhan
    PUBLIC
    ${CMAKE_CURRENT_SOURCE_DIR}/third_party/adhan-cpp/include
)